---
import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import Hero from '../components/Hero.astro';


import portraitImage from '../assets/at-work.jpg';
import { Image } from 'astro:assets';
---

<BaseLayout title="About | Bernhard Wittmann" description="About Bernhard Wittmann">
	<div class="stack gap-20">
		<div class="wrapper about">
			<Hero
				title="About"
				tagline="Senior Full Stack Engineer based in Innsbruck. Building products from idea to production for 8+ years."
			>
				<Image
					width="1553"
					height="873"
					src={portraitImage}
					alt="Portrait of Bernhard Wittmann"
					
				/>
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
					<p>
						I am a Senior Full Stack Engineer with over 8 years of experience building and scaling products at startups. I have led mobile and backend development for fintech apps with more than 150,000 users, taking projects from idea to production. I worked as a Senior Software Engineer at Monkee GmbH, a Founding Engineer at finbalanced, and co-founded Digitales Wartezimmer e.V., contributing to web and mobile platforms while mentoring junior developers and making key architectural decisions. My experience spans mobile, web, and backend development, as well as product delivery and technical integration with banking systems.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
				<div class="content">
					<p>
						I hold a Master’s degree in Software Engineering from the University of Ulm (2017–2020) and a Bachelor’s in TUM-BWL with a focus on Computer Science from the Technical University of Munich (2014–2017). I also attended a summer program at the University of California, Berkeley (May–July 2016), which broadened my leadership skills and international exposure.
					</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
				<div class="content">
					<dl class="skills-list">
						<div>
							<dt>Frontend</dt>
							<dd>React, React Native, NextJS, Vue, TypeScript, HTML/CSS</dd>
						</div>
						<div>
							<dt>Backend</dt>
							<dd>NodeJS, NestJS, Python/Django, Java, PostgreSQL, Docker</dd>
						</div>
						<div>
							<dt>Practices</dt>
							<dd>Jest, Cypress, CI/CD, Git, Agile/Scrum</dd>
						</div>
						<div>
							<dt>Languages</dt>
							<dd>German (native), English (fluent)</dd>
						</div>
					</dl>
				</div>
			</section>
		</div>

		<ContactCTA leftText='Want to see my full resume?'/>
	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
		object-position: top center;
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-2xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(.skills-list) {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		padding: 0;
	}

	.content :global(.skills-list div) {
		display: grid;
		grid-template-columns: 6rem 1fr;
		gap: 0.5rem;
		padding-bottom: 0.75rem;
		margin-bottom: 0.75rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.content :global(.skills-list div:last-child) {
		border-bottom: none;
		margin-bottom: 0;
	}

	.content :global(.skills-list dt) {
		color: var(--gray-0);
		font-weight: 600;
	}

	.content :global(.skills-list dd) {
		margin: 0;
		color: var(--gray-200);
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}
</style>
