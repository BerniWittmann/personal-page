---
interface Props {
	title: string;
	tagline?: string;
	align?: 'start' | 'center';
}

const { align = 'center', tagline, title } = Astro.props;
---

<header class:list={['hero stack gap-4', align]}>
	<div class="stack gap-2">
		<div class="title-wrap">
			<h1 class="title">{title}</h1>
			<div class="title-accent" aria-hidden="true"></div>
		</div>
		{tagline && <p class="tagline">{tagline}</p>}
	</div>
	<slot />
</header>

<style>
	.hero {
		font-size: var(--text-lg);
		text-align: center;
	}

	.title-wrap {
		position: relative;
		display: inline-block;
	}

	.title,
	.tagline {
		max-width: 37ch;
		margin-inline: auto;
	}

	.title {
		font-size: var(--text-3xl);
		color: var(--gray-0);
		font-weight: 700;
		letter-spacing: -0.03em;
	}

	.title-accent {
		display: none;
	}

	@media (min-width: 50em) {
		.hero {
			font-size: var(--text-xl);
		}

		.start {
			text-align: start;
		}

		.start .title,
		.start .tagline {
			margin-inline: unset;
		}

		.title {
			font-size: var(--text-5xl);
		}

		/* Decorative underline accent for the hero title */
		.start .title-accent {
			display: block;
			height: 4px;
			width: 3.5rem;
			background: linear-gradient(90deg, var(--accent-regular), var(--accent-light));
			border-radius: 2px;
			margin-top: 1rem;
			margin-bottom: 0.25rem;
		}
	}
</style>
