---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'>;
}

const { data, id } = Astro.props.project;
---

<a class="card" href={`/work/${id}`}>
	<div class="image-wrap">
		<Image src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
	</div>
	<div class="card-footer">
		<span class="title">{data.title}</span>
		<span class="arrow">→</span>
	</div>
</a>

<style>
	.card {
		display: flex;
		flex-direction: column;
		height: 100%;
		background: var(--gray-999);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-brand);
		transition:
			box-shadow var(--theme-transition),
			border-color var(--theme-transition),
			transform var(--theme-transition);
	}

	.card:hover {
		box-shadow: var(--shadow-md);
		border-color: var(--stone-light);
		transform: translateY(-2px);
	}

	.image-wrap {
		overflow: hidden;
		height: 11rem;
		flex-shrink: 0;
	}

	.image-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.4s ease;
	}

	.card:hover .image-wrap img {
		transform: scale(1.04);
	}

	.card-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.875rem 1.125rem;
		border-top: 1px solid var(--gray-800);
		gap: 0.5rem;
	}

	.title {
		font-size: var(--text-base);
		font-weight: 500;
		color: var(--gray-100);
		line-height: 1.3;
	}

	.arrow {
		color: var(--stone);
		font-size: var(--text-lg);
		flex-shrink: 0;
		transition: color var(--theme-transition), transform var(--theme-transition);
	}

	.card:hover .arrow {
		color: var(--accent-regular);
		transform: translateX(3px);
	}

	@media (min-width: 50em) {
		.card {
			border-radius: 1rem;
		}

		.image-wrap {
			height: 20rem;
		}

		.title {
			font-size: var(--text-md);
		}

		.card-footer {
			padding: 1rem 1.5rem;
		}
	}
</style>
