---
import Icon from './Icon.astro';
const currentYear = new Date().getFullYear();
---

<footer>
	<div class="group">
		<p>&copy; {currentYear} Bernhard Wittmann</p>
	</div>
	<p class="socials">
		<a href="mailto:contact@bernhardwittmann.com">E-Mail</a>
		<a href="https://github.com/BerniWittmann">GitHub</a>
		<a href="https://gitlab.com/BerniWittmann">GitLab</a>
		<a href="http://linkedin.com/in/bernhard-wittmann">LinkedIn</a>
	</p>
</footer>
<style>
	footer {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		margin-top: auto;
		padding: 3rem 2rem;
		text-align: center;
		color: var(--gray-400);
		font-size: var(--text-sm);
		border-top: 1px solid var(--gray-800);
		background-color: var(--gray-999);
	}

	footer a {
		color: var(--gray-300);
		text-decoration: none;
		transition: color var(--theme-transition);
	}

	footer a:hover,
	footer a:focus {
		color: var(--accent-regular);
	}

	.group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-500);
	}

	.socials {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	@media (min-width: 50em) {
		footer {
			flex-direction: row;
			justify-content: space-between;
			padding: 2rem 4rem;
		}

		.group {
			flex-direction: row;
			gap: 1rem;
			flex-wrap: wrap;
		}

		.socials {
			justify-content: flex-end;
		}
	}
</style>
