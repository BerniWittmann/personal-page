---
import '../styles/global.css';
import { SEO } from "astro-seo";

interface Props {
	title?: string | undefined;
	description?: string | undefined;
}

const {
	title = 'Bernhard Wittmann',
	description = 'The personal site of Bernhard Wittmann, a Senior Full Stack Engineer with 8+ years of experience building products at startups in Austria.',
} = Astro.props;
---

<meta charset="UTF-8" />
<meta name="description" property="og:description" content={description} />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.bunny.net">
<link
	href="https://fonts.bunny.net/css?family=Public+Sans:ital,wght@0,400;0,700;1,400&family=Rubik:wght@500;600&display=swap"
	rel="stylesheet"
/>
<link rel="sitemap" href="/sitemap-index.xml" />

<SEO
	title="Personal Page of Bernhard Wittmann"
	description="Bernhard Wittmann is a Senior Full Stack Engineer with 8+ years of experience building products at startups in Austria. Hands-on across mobile, web, and backend, owning features from idea to production."
	openGraph={{
		basic: {
			title: 'Bernhard Wittmann',
			type: "profile",
			url: 'https://bernhardwittmann.com',
			image: "https://bernhardwittmann.com/assets/og-image.jpg",
		}
	}}
	extend={{
		// extending the default link tags
		link: [{ rel: "icon", href: "/favicon.ico" }],
		// extending the default meta tags
		meta: [],
	}}
/>

